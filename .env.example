APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Face match microservice: Docker Compose service name + internal port.
# Production (app + face_match on opticedge_internal): http://face_match:8001
# Local PHP without Docker: leave empty, or run face_match with -p 8001:8001 and use http://127.0.0.1:8001
FACE_MATCH_URL=http://face_match:8001
# Cosine similarity 0–1: >= PASS auto-accept; >= REVIEW but < PASS → review queue; else failed.
# Tighten security by raising PASS (e.g. 0.80); widen review band by lowering REVIEW (e.g. 0.50).
FACE_MATCH_PASS_THRESHOLD=0.6
FACE_MATCH_REVIEW_THRESHOLD=0.59
FACE_MATCH_MIN_FACE_AREA_RATIO=0.045
FACE_MATCH_MIN_SHARPNESS=35
FACE_MATCH_MIN_BRIGHTNESS=35
FACE_MATCH_MAX_BRIGHTNESS=225

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SELCOM_BASE_URL=https://apigw.selcommobile.com/v1
SELCOM_VENDOR=
SELCOM_API_KEY=
SELCOM_API_SECRET=

VITE_APP_NAME="${APP_NAME}"


DEVICE_CATALOG_ENABLED=true
DEVICE_CATALOG_PROVIDER=mobileapi
MOBILEAPI_BASE_URL=https://api.mobileapi.dev
MOBILEAPI_KEY=739eb9f66c724d2c9e8dd4ea548f11333fc4ecc7
MOBILEAPI_CONNECT_TIMEOUT=5
MOBILEAPI_TIMEOUT=20
